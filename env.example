# Feishu self-built app credentials. Keep real values in a private .env file.
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Default group chat for read/send helpers. Do not commit real chat IDs.
FEISHU_TARGET_CHAT_ID=oc_xxx

# Optional bot open_id, useful for deployments that need to identify their bot user.
FEISHU_BOT_OPEN_ID=ou_xxx

# Feishu permissions:
# - Send messages: message send permission, such as im:message:send_as_bot
# - Read group history: im:message.group_msg or equivalent
# - Read message resources: permissions for getting resource files in messages
# - Resolve @ mentions by member name: chat member read permission
# - Download Drive files/media: Drive media/file read and download permissions
# - Bitable read: Base/Bitable app, table, field, and record read permissions
# - Bitable write: Base/Bitable record create and update permissions
# Base files may also need the app added as a collaborator or allowlisted in advanced permissions.
