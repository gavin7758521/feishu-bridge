FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_TARGET_CHAT_ID=oc_xxx
FEISHU_BOT_OPEN_ID=ou_xxx

# Reply modes:
# - echo: reply with a simple receipt
# - codex: run Codex CLI with a constrained prompt
# - command: pipe message text to FEISHU_BRIDGE_REPLY_COMMAND and reply with stdout
FEISHU_BRIDGE_MODE=echo
FEISHU_BRIDGE_MAX_REPLY_CHARS=3500
FEISHU_BRIDGE_LOCK_FILE=/tmp/feishu-bridge.lock

# Generic command mode. The command receives message text on stdin and these env vars:
# FEISHU_MESSAGE_TEXT, FEISHU_CHAT_ID, FEISHU_MESSAGE_ID, FEISHU_SENDER_OPEN_ID
FEISHU_BRIDGE_REPLY_COMMAND=
FEISHU_BRIDGE_REPLY_COMMAND_CWD=/path/to/project
FEISHU_BRIDGE_REPLY_COMMAND_TIMEOUT_MS=120000
FEISHU_BRIDGE_REPLY_COMMAND_MAX_BUFFER=5242880

# Codex mode compatibility. Existing deployments may still use CODEX_BRIDGE_MODE.
CODEX_BRIDGE_MODE=echo
CODEX_BRIDGE_CWD=/path/to/workspace
CODEX_BRIDGE_TIMEOUT_MS=120000
CODEX_BRIDGE_MAX_REPLY_CHARS=3500

# Feishu permissions:
# - Send messages: message send permission, such as im:message:send_as_bot
# - Read group history: im:message.group_msg
# - Resolve @ mentions by member name: chat member read permission
